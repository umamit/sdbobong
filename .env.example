# Supabase Configuration
# Masukkan URL project Supabase Anda (bisa dilihat di Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_URL=https://your-project-id.supabase.co

# Anon Key (Untuk client-side/browser, aman dipublikasikan secara client-side)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service Role Key / Service Key (Untuk backend/server-side bypass RLS)
# WARNING: Jangan pernah memprefix key ini dengan NEXT_PUBLIC_ atau membagikannya ke client!
SUPABASE_KEY=your-service-role-key

# Groq API Key (Untuk chatbot Aim AI gratis bertenaga Llama 3)
# Dapatkan kunci API gratis Anda di https://console.groq.com/
GROQ_API_KEY=gsk_your-groq-api-key-here


